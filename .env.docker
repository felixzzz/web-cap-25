# Docker-specific env — used inside the Next.js container.
# API_URL uses the Docker service name so SSR calls resolve correctly.
# NEXT_PUBLIC_ vars use localhost so the browser (on the host) can reach the CMS.
SITE_URL=http://cap.test
NEXT_PUBLIC_SITE_URL=http://cap.test
API_URL=http://chandra-asri-cms:8000
NEXT_PUBLIC_API_URL=http://canasite.cap.test
IMAGE_URL=http://localhost:8000/storage
NEXT_PUBLIC_IMAGE_URL=http://canasite.cap.test/storage
